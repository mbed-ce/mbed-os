{
    "overrides": {
        // Enable Mbed Stats tests
        "platform.all-stats-enabled": 1,

        // Enable auto reboot on error, required for crash reporting test
        "platform.fatal-error-auto-reboot-enabled": true,

        // Make sure that the MCU keeps rebooting when a fatal error occurs, because some
        // flash tools won't reset the crash data RAM, so fatal errors will prevent even new, different
        // code flashed to the MCU from being able to run during a test run
        "platform.error-reboot-max": 2147483648
    }
}
